# GCP RUN Marketplace - Flutter App Configuration
# Copy this file to .env and fill in your values

# API Configuration
API_BASE_URL=https://api.gcprun.com/v1
API_CONNECT_TIMEOUT=30000
API_RECEIVE_TIMEOUT=30000

# Midtrans Payment
MIDTRANS_CLIENT_KEY=SB-Mid-client-XXXXXX
MIDTRANS_SERVER_KEY=SB-Mid-server-XXXXXX
MIDTRANS_IS_PRODUCTION=false

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Feature Flags
ENABLE_KYC=true
ENABLE_AI_CREDIT_SCORE=true
ENABLE_MIDTRANS_PAYMENT=true
